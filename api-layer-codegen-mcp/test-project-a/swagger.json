{
  "swagger": "2.0",
  "info": {
    "title": "Petstore Swagger Harness API",
    "version": "1.0.0"
  },
  "basePath": "/",
  "paths": {
    "/pets": {
      "get": {
        "operationId": "listSwaggerPets",
        "responses": {
          "200": {
            "description": "A list of pets",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Pet"
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "Pet": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    }
  }
}
